<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.kuromi.mapper.SysOrderItemMapper">

    <!-- 根据订单号查询订单项 -->
    <select id="selectByOrderNo" resultType="SysOrderItem">
        SELECT * FROM sys_order_item
        WHERE order_no = #{orderNo}
    </select>

</mapper>